# ── Vercel KV (get from Vercel dashboard → Storage → KV) ──────────────────────
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ── Resend (free email — https://resend.com) ───────────────────────────────────
# Free tier: 3,000 emails/month, 100/day. No credit card needed.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=alerts@yourdomain.com   # must be a verified sender in Resend

# ── Fast2SMS (free Indian SMS — https://fast2sms.com) ─────────────────────────
# Free credits on signup (~500 SMS). Top up at ₹200/1000 SMS if needed.
FAST2SMS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cron security token (make up any random string) ───────────────────────────
CRON_SECRET=my_super_secret_cron_token_123
